# JeraAIBoss shared reverse proxy — one block per app, routed by hostname.
# Each app stays on its private localhost port (see port registry).
pulse.jera.co.za {
    encode zstd gzip
    reverse_proxy 127.0.0.1:3000
}
# --- future apps: add a block when deployed ---
