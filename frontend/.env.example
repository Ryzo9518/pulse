# ============================================
# PULSE Environment Variables
# Copy this to .env.local and fill in values. NEVER commit .env.local.
# ============================================

# --- Auth.js / Microsoft Entra ID (Microsoft sign-in) ---
# Public URL the app is served at (Auth.js builds callback URLs from this).
AUTH_URL=https://pulse.jera.co.za
# Required when running behind a reverse proxy (Caddy).
AUTH_TRUST_HOST=true
# Random 32+ byte secret: `openssl rand -base64 33`
AUTH_SECRET=generate_me
# Entra app registration (App ID / Tenant). These are config, not secrets.
AUTH_MICROSOFT_ENTRA_ID_ID=46282e6c-0200-498e-adaf-a9dbb52122b1
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/4f124a4c-a71e-463c-a004-f65515cff124/v2.0
# Entra client SECRET — sensitive. On the server this is read from the secret
# store, never committed.
AUTH_MICROSOFT_ENTRA_ID_SECRET=from_secret_store

# --- Pulse data API (PostgREST) ---
# Internal URL of the PostgREST data API on the box.
PULSE_POSTGREST_URL=http://127.0.0.1:3001
# The SAME HS256 secret PostgREST validates with. Server-only — NEVER expose.
PULSE_PG_JWT_SECRET=from_secret_store
# Service-role JWT (role=service_role) used server-side for the sign-in employee
# lookup + first-login auth_user_id relink. Server-only — NEVER expose.
PULSE_SERVICE_JWT=from_secret_store
# Field-encryption key for POPIA-sensitive form data (ID/tax/banking/medical).
# base64 of 32 random bytes: `openssl rand -base64 32`. Server-only; store a copy
# OFF the box (losing it makes the encrypted form data unrecoverable).
PULSE_FIELD_KEY=from_secret_store

# --- App config ---
NEXT_PUBLIC_APP_URL=https://pulse.jera.co.za
NEXT_PUBLIC_APP_NAME=PULSE
# Data source for screens migrated to live data (B2): `live` routes through the
# authenticated /api/rest proxy (RLS-enforced); anything else uses mock data.
# NEXT_PUBLIC_* is baked at build time — changing it requires a rebuild.
NEXT_PUBLIC_PULSE_DATA=mock
