# ============================================
# PULSE Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- Microsoft 365 sign-in (Auth.js / Entra ID) — SERVER ONLY ---
# Client/Tenant are config (not secrets); the SECRET and JWT values are.
AUTH_MICROSOFT_ENTRA_ID_ID=46282e6c-0200-498e-adaf-a9dbb52122b1
AUTH_MICROSOFT_ENTRA_ID_SECRET=__client_secret_from_box__
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/4f124a4c-a71e-463c-a004-f65515cff124/v2.0
# Auth.js session encryption secret (generate: `openssl rand -base64 32`)
AUTH_SECRET=__generate_with_openssl_rand_base64_32__
# Required when not on localhost (e.g. behind a tunnel/proxy)
# AUTH_URL=http://localhost:3000

# --- Pulse data layer (PostgREST + Postgres) — SERVER ONLY ---
PULSE_POSTGREST_URL=http://127.0.0.1:3001
# The SAME HS256 secret PostgREST verifies with (~/pulse-db/.jwt_secret on the box)
PULSE_PG_JWT_SECRET=__shared_postgrest_hs256_secret__
# Service-role JWT used only for the one-time first-login employee relink
PULSE_SERVICE_JWT=__service_role_jwt__

# --- App config ---
NEXT_PUBLIC_APP_URL=https://pulse.jera.co.za
NEXT_PUBLIC_APP_NAME=PULSE

# --- Legacy (mock/early-scaffold; not used by Microsoft sign-in) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
